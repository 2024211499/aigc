# ══════════════════════════════════════════════════════════════
#   AIGC 智能学习资源生成平台 —— 环境变量模板
#   使用说明：复制本文件为 .env，填写必填项后启动服务
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────────────────────
# 【必填】LLM 大语言模型（2号 Agent 模块 & 3号后端降级直调共用）
#   兼容任意 OpenAI 接口协议，推荐 DeepSeek
# ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_deepseek_or_openai_api_key_here
OPENAI_API_BASE=https://api.deepseek.com/
LLM_MODEL_NAME=deepseek-v4-flash

# CrewAI 框架使用（与 LLM_MODEL_NAME 保持一致即可）
CREWAI_LLM_MODEL=deepseek-v4-flash


# ──────────────────────────────────────────────────────────────
# 【必填】Embedding 向量化（1号 RAG 模块 & 3号后端向量检索共用）
#   推荐 SiliconFlow BAAI/bge-m3，或使用本地 sentence-transformers
#
#   ⚠️ 注意：当前 rag/bridge.py 已切换为本地模型
#   (provider="local", model="paraphrase-multilingual-MiniLM-L12-v2")
#   若要启用 SiliconFlow API，需修改 backend/app/rag/bridge.py
#   并将 rag/embeddings.py 中的 openai.Embedding.create 升级至 v1.x API
# ──────────────────────────────────────────────────────────────
EMBEDDING_API_KEY=your_siliconflow_api_key_here
EMBEDDING_API_BASE=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3


# ──────────────────────────────────────────────────────────────
# 【可选】多模态 LLM（带图提问专用）
#   纯文字提问走 DeepSeek；截图/拍照提问走这个
#   推荐 Qwen-VL（阿里云百炼），支持 base64 图片，中文优秀且有免费额度
#   如果用 Step-1V（阶跃星辰）：
#     API_BASE=https://api.stepfun.com/v1
#     MODEL=step-1v
#   如不配置，带图提问会自动回退到 OCR + 纯文字 DeepSeek
# ──────────────────────────────────────────────────────────────
# MULTIMODAL_API_KEY=your_dashscope_api_key
# MULTIMODAL_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# MULTIMODAL_MODEL=qwen-vl-plus


# ──────────────────────────────────────────────────────────────
# 【可选】数据库
#   默认使用 SQLite（backend/data/aigc.db），开发阶段无需修改
#   生产环境建议切换至 PostgreSQL 以支持并发
# ──────────────────────────────────────────────────────────────
# SQLite（默认，无需填写）
# DATABASE_URL=sqlite:///./data/aigc.db

# PostgreSQL（生产环境推荐）
# DATABASE_URL=postgresql://user:password@localhost:5432/aigc_db


# ──────────────────────────────────────────────────────────────
# 【可选】Redis（2号 Agent 记忆模块使用）
#   若未安装 Redis，memory_manager 会自动降级，不影响核心功能
# ──────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# REDIS_URL=redis://:password@localhost:6379/0  # 也可用 URL 形式


# ──────────────────────────────────────────────────────────────
# 【可选】PostgreSQL（2号 Agent 会话记忆持久化）
#   用于存储 study_sessions / knowledge_points 等记忆表
#   若未连接，记忆模块会静默降级
# ──────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DB=aigc_memory
PG_USER=postgres
PG_PASSWORD=your_postgres_password_here


# ──────────────────────────────────────────────────────────────
# 【可选】OCR（1号 RAG 文档解析 OCR）
#   支持：tesseract（本地）、paddle（本地）、baidu、tencent、vivo
#   在线 OCR 需要设置 enable_online_ocr=True
# ──────────────────────────────────────────────────────────────
# VIVO_OCR_APP_ID=your_vivo_app_id
# VIVO_OCR_APP_KEY=your_vivo_app_key
# BAIDU_OCR_API_KEY=your_baidu_api_key
# BAIDU_OCR_SECRET_KEY=your_baidu_secret_key
# TENCENT_SECRET_ID=your_tencent_secret_id
# TENCENT_SECRET_KEY=your_tencent_secret_key


# ──────────────────────────────────────────────────────────────
# 【可选】文件上传限制
# ──────────────────────────────────────────────────────────────
# 单文件最大体积，单位字节，默认 100MB
MAX_UPLOAD_SIZE=104857600


# ──────────────────────────────────────────────────────────────
# 【可选】CORS 跨域配置
#   开发阶段留空即可（默认 allow_origins=["*"]，不携带凭据）
#   生产环境必须填写前端域名，否则浏览器会因 credentials 拒绝请求
#   多个域名用英文逗号分隔
# ──────────────────────────────────────────────────────────────
# CORS_ORIGINS=http://localhost:3000,https://your-frontend.com


# ──────────────────────────────────────────────────────────────
# 【可选】模块路径（bridge 层自动探测，通常无需修改）
#   相对路径以项目根目录为基准
# ──────────────────────────────────────────────────────────────
# RAG_MODULE_DIR=../rag
# AGENT_MODULE_DIR=../agents


# ──────────────────────────────────────────────────────────────
# 【可选】日志级别
#   DEBUG / INFO / WARNING / ERROR
# ──────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
